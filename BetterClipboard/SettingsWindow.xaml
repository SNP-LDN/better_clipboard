<Window x:Class="BetterClipboard.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Icon="Assets/Brand/better-clipboard.ico"
        Width="430"
        Height="620"
        MinWidth="390"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="恢复默认值"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="ResetDefaults_Click" />
            <Button Content="取消"
                    Width="86"
                    Height="32"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
            <Button Content="保存"
                    Width="86"
                    Height="32"
                    IsDefault="True"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Save_Click" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="0,0,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Width="36"
                       Height="36"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Source="Assets/Brand/better-clipboard-app-icon.png"
                       Stretch="Uniform" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Better Clipboard 设置"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="调整外观、历史记录与隐私选项。"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Padding="12"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="外观"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="155" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="明暗模式"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <ComboBox x:Name="ThemeModeBox"
                                  Grid.Column="1"
                                  Height="30"
                                  SelectionChanged="Appearance_SelectionChanged">
                            <ComboBoxItem Content="跟随系统" Tag="System" />
                            <ComboBoxItem Content="浅色" Tag="Light" />
                            <ComboBoxItem Content="深色" Tag="Dark" />
                        </ComboBox>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="155" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="界面风格"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <ComboBox x:Name="ThemePresetBox"
                                  Grid.Column="1"
                                  Height="30"
                                  SelectionChanged="Appearance_SelectionChanged">
                            <ComboBoxItem Content="清爽标准" Tag="Standard" />
                            <ComboBoxItem Content="柔和玻璃" Tag="Glass" />
                        </ComboBox>
                    </Grid>
                    <Grid x:Name="GlassOpacityPanel"
                          Margin="0,8,0,0"
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="155" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="透明度"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="GlassOpacitySlider"
                                    Minimum="55"
                                    Maximum="95"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock x:Name="GlassOpacityText"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="普通记录保留天数"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="收藏项会一直保留，直到手动删除。"
                               Margin="0,3,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" />
                </StackPanel>
                <TextBox x:Name="RetentionDaysBox"
                         Grid.Column="1"
                         Height="30"
                         Padding="8,4"
                         HorizontalContentAlignment="Right"
                         VerticalContentAlignment="Center" />
            </Grid>

            <StackPanel Grid.Row="3" Margin="0,18,0,0">
                <CheckBox x:Name="SaveImagesCheckBox"
                          Content="保存图片和截图到历史"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource TextPrimaryBrush}" />

                <TextBlock Text="应用黑名单"
                           Margin="0,18,0,0"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="每行一个进程名或关键词，匹配到的来源不会保存。"
                           Margin="0,3,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12" />
                <TextBox x:Name="BlockedAppsBox"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         Padding="8"
                         FontFamily="Consolas"
                         FontSize="13"
                         MinHeight="130" />
            </StackPanel>

            <Border Grid.Row="4"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource SurfaceBrush}"
                    Padding="12"
                    Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="记录状态"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock x:Name="PauseStatusText"
                                   Margin="0,3,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="恢复记录"
                            Width="86"
                            Height="30"
                            VerticalAlignment="Center"
                            Click="Resume_Click" />
                </Grid>
            </Border>
        </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
