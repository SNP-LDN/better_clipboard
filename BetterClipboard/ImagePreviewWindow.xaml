<Window x:Class="BetterClipboard.ImagePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图片预览"
        Icon="Assets/Brand/better-clipboard.ico"
        Width="900"
        Height="650"
        MinWidth="420"
        MinHeight="320"
        WindowStartupLocation="CenterScreen"
        Background="#171A1C">
    <Grid>
        <Image x:Name="PreviewImage"
               Margin="16"
               Stretch="Uniform"
               SnapsToDevicePixels="True" />
        <Border HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="14"
                Padding="8,4"
                Background="#CC242A2E"
                CornerRadius="4">
            <TextBlock x:Name="ImageInfo"
                       Foreground="White"
                       FontSize="12" />
        </Border>
    </Grid>
</Window>
